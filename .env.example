# Copiá este archivo a ".env" y ajustá los valores.

# Puerto público del tablero (http://localhost:<HTTP_PORT>)
HTTP_PORT=8686

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=dashboard
MYSQL_USER=dashboard
MYSQL_PASSWORD=dashboard
MYSQL_PORT=3308

# ── Autenticación ───────────────────────────────────────────────────
# Secreto de firma del JWT. Mínimo 32 bytes: la app no arranca si falta o es corto.
# Generar con:  openssl rand -base64 48
JWT_SECRET=
# Duración de la sesión, en horas.
JWT_TTL_HOURS=12
# Poner en true SÓLO si el tablero se sirve por HTTPS. Con true sobre HTTP el
# browser descarta la cookie y el login deja de funcionar.
JWT_COOKIE_SECURE=false

# Usuario admin inicial. Se crea al arrancar si no existe; si ya existe no se toca.
# Sin ADMIN_PASSWORD no se crea ningún usuario y no se puede entrar al tablero.
ADMIN_USER=admin
ADMIN_PASSWORD=
